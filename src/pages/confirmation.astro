---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Call Confirmed | Furum Consulting"
      description="Your Furum Consulting discovery call is confirmed. Review the next steps before your call."
      noindex={true}
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="confirmation-section noise-bg">
        <div class="grid-bg"></div>
        <div class="glow"></div>

        <div class="container">
          <div class="confirmation-header">
            <p class="eyebrow">Step 3: Confirmation</p>
            <h1>Your Discovery Call Is Booked</h1>
            <p>
              You are booked in. Before the call, complete the three steps below so
              we can use the time to review your agency, niche, candidate inventory,
              and current client acquisition motion.
            </p>
          </div>

          <div class="confirmation-note">
            <strong>What happens next</strong>
            <p>
              We will use the call to understand where your clients currently come from,
              what roles and candidates you specialize in, and whether an MPC-led
              pay-per-call system is a strong fit for your market.
            </p>
          </div>

          <div class="steps-grid">
            <article class="step-card">
              <span>01</span>
              <strong>Accept the Calendar Invite</strong>
              <p>Make sure the invite is on your calendar so the time is locked in.</p>
            </article>
            <article class="step-card">
              <span>02</span>
              <strong>Confirm the Call</strong>
              <p>Reply to any confirmation message so we know you are still attending.</p>
            </article>
            <article class="step-card">
              <span>03</span>
              <strong>Show Up Prepared</strong>
              <p>Bring your niche, candidate inventory, and current BD context to the call.</p>
            </article>
          </div>

          <div class="footer-note">
            <a href="/">Back to site</a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .confirmation-section {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 4rem 0;
    background: var(--page-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.7;
  }

  .glow {
    position: absolute;
    top: -8rem;
    left: 50%;
    width: 34rem;
    height: 18rem;
    border-radius: 999px;
    background: var(--accent-bg-strong);
    filter: blur(90px);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, 1040px);
    margin: 0 auto;
  }

  .confirmation-header {
    max-width: 820px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 1rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .confirmation-header p {
    margin: 1rem auto 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.55;
  }

  .confirmation-note {
    max-width: 860px;
    margin: 0 auto;
    border: 1px solid var(--accent-border);
    border-radius: 1rem;
    background: var(--surface2);
    padding: 1.5rem;
    box-shadow: 0 18px 60px var(--shadow-color);
  }

  .confirmation-note strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.35rem;
    font-weight: 700;
  }

  .confirmation-note p {
    margin: 0.65rem 0 0;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  .step-card {
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: var(--surface2);
  }

  .step-card span {
    display: block;
    margin-bottom: 0.7rem;
    color: var(--number-color);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
  }

  .step-card strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.25rem;
  }

  .step-card p {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .footer-note {
    margin-top: 2rem;
    text-align: center;
  }

  .footer-note a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  @media (min-width: 800px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .confirmation-section {
      padding: 3rem 0;
    }

    .eyebrow {
      max-width: 20rem;
      padding: 0.45rem 0.75rem;
      font-size: 0.62rem;
      line-height: 1.35;
      letter-spacing: 0.08em;
    }
  }
</style>
