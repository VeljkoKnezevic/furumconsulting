---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Book Your Discovery Call | Furum Consulting"
      description="Book a discovery call with Furum Consulting to see if the MPC Demand Engine is a fit for your staffing or recruiting agency."
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="booking-section noise-bg">
        <div class="grid-bg"></div>
        <div class="glow glow-top"></div>

        <div class="container">
          <div class="booking-header">
            <p class="eyebrow">Step 2: Book your call</p>
            <h1>Pick a Time for Your Discovery Call</h1>
            <p>
              Use the calendar below to book a time. We will look at your niche,
              candidate inventory, and current BD motion to see whether the MPC
              Demand Engine can produce qualified hiring manager conversations for you.
            </p>
          </div>

          <div class="calendar-card">
            <div id="cal-embed" class="cal-embed"></div>
          </div>
        </div>
      </section>

      <section class="proof-section">
        <div class="container">
          <div class="section-header">
            <p class="section-kicker">Before you book</p>
            <h2>The call is for agencies that want a repeatable client acquisition system.</h2>
          </div>

          <div class="proof-grid">
            <article class="proof-card">
              <strong>Best fit</strong>
              <span>Specialist staffing or recruiting agencies with a clear niche and candidates they can place.</span>
            </article>
            <article class="proof-card">
              <strong>What we inspect</strong>
              <span>Your market, bench, offer, outbound setup, and ability to serve new hiring demand.</span>
            </article>
            <article class="proof-card">
              <strong>What you leave with</strong>
              <span>A clear view of whether pay-per-call MPC outreach makes sense for your agency.</span>
            </article>
          </div>
        </div>
      </section>
    </main>

    <script>
      function getCalTheme(): "light" | "dark" {
        return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      }

      (function (C: any, A: string, L: string) {
        const p = function (a: any, ar: IArguments) {
          a.q.push(ar);
        };
        const d = C.document;
        C.Cal = C.Cal || function () {
          const cal = C.Cal;
          const ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () {
              p(api, arguments);
            };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      const calTheme = getCalTheme();
      (window as any).Cal("init", "discovery-call", { origin: "https://app.cal.com" });
      (window as any).Cal.ns["discovery-call"]("inline", {
        elementOrSelector: "#cal-embed",
        calLink: "furumconsulting/discovery-call",
        config: {
          theme: calTheme,
          layout: "month_view"
        }
      });
      (window as any).Cal.ns["discovery-call"]("ui", {
        theme: calTheme,
        styles: {
          branding: {
            brandColor: "#2d5d52"
          }
        },
        hideEventTypeDetails: false
      });
    </script>
  </body>
</html>

<style>
  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .booking-section,
  .proof-section {
    position: relative;
    overflow: hidden;
  }

  .booking-section {
    padding: 4rem 0 5rem;
    background: var(--page-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.7;
  }

  .glow {
    position: absolute;
    top: -8rem;
    left: 50%;
    width: 34rem;
    height: 18rem;
    border-radius: 999px;
    background: var(--accent-bg-strong);
    filter: blur(90px);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, 1100px);
    margin: 0 auto;
  }

  .booking-header,
  .section-header {
    max-width: 820px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .eyebrow,
  .section-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 1rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-weight: 700;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 5rem);
    line-height: 0.95;
  }

  h2 {
    font-size: clamp(1.9rem, 3.5vw, 3.6rem);
    line-height: 1;
  }

  .booking-header p {
    margin: 1rem auto 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.55;
  }

  .calendar-card {
    overflow: hidden;
    border: 1px solid var(--accent-border);
    border-radius: 1rem;
    background: var(--surface2);
    box-shadow: 0 18px 60px var(--shadow-color);
  }

  .cal-embed {
    width: 100%;
    min-height: 680px;
  }

  .proof-section {
    padding: 5rem 0;
    border-top: 1px solid var(--border-subtle);
    background: var(--surface);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .proof-card {
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: var(--page-bg);
  }

  .proof-card strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.2rem;
  }

  .proof-card span {
    display: block;
    margin-top: 0.45rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (min-width: 800px) {
    .proof-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .booking-section {
      padding: 3rem 0 4rem;
    }

    .eyebrow {
      max-width: 20rem;
      padding: 0.45rem 0.75rem;
      font-size: 0.62rem;
      line-height: 1.35;
      letter-spacing: 0.08em;
    }

    .cal-embed {
      min-height: 720px;
    }
  }
</style>
