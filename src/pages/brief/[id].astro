---
import BaseHead from "../../components/BaseHead.astro";
import { renderBrief } from "../../lib/brief-render";
import type { StoredBrief } from "../../lib/brief";
import "../../styles/brief.css";

const { id } = Astro.params;
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://cal.com/furumconsulting/discovery-call";

let stored: StoredBrief | null = null;
if (id && /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id)) {
	stored = await Astro.locals.runtime.env.BRIEFS.get<StoredBrief>(`brief:${id}`, "json");
}

if (!stored) {
	Astro.response.status = 404;
}

const briefHtml = stored ? renderBrief(stored.brief) : "";
const preparedDate = stored
	? new Date(stored.createdAt).toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: "";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Candidate Marketing Brief"
      description="An anonymized MPC candidate marketing brief generated by Furum Consulting."
      noindex={true}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/"><img src="/logo-light.png" alt="Furum Consulting" class="logo" /></a>
      </div>
    </header>

    <main class="page-shell">
      <section class="brief-page-section">
        <div class="container">
          {
            stored ? (
              <>
                <div class="prepared-line no-print">
                  <p>Prepared for <strong>{stored.firstName}</strong> on {preparedDate}</p>
                  <a class="pdf-button" href={`/brief/${id}.pdf`}>Download PDF</a>
                </div>
                <article class="brief" set:html={briefHtml} />
                <aside class="brief-cta">
                  <p>
                    This is a preview of what we build for staffing agencies at scale: full
                    MPC campaigns, target lists, and outbound infrastructure. Book 15 minutes.
                  </p>
                  <a class="cta-button" href={bookingUrl}>Book 15 Minutes</a>
                </aside>
              </>
            ) : (
              <div class="not-found">
                <h1>This brief has expired or doesn't exist</h1>
                <p>Briefs are stored for 90 days. You can generate a fresh one in about a minute.</p>
                <a class="cta-button" href="/candidate-brief">Generate a New Brief</a>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Furum Consulting. All rights reserved.</p>
      </div>
    </footer>

    <script>
      import { initCopyButtons } from "../../lib/brief-render";
      initCopyButtons(document.body);
    </script>
  </body>
</html>

<style>
  .container {
    width: min(100% - 2rem, 1120px);
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    overflow: visible;
  }

  .logo {
    height: 7.5rem;
    width: auto;
    margin-left: -0.75rem;
    object-fit: contain;
  }

  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .brief-page-section {
    padding: 2.5rem 0 5rem;
  }

  .prepared-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 780px;
    margin: 0 auto 1.5rem;
    text-align: center;
  }

  .prepared-line p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .prepared-line strong {
    color: var(--text-primary);
  }

  .not-found {
    max-width: 560px;
    margin: 4rem auto;
    text-align: center;
  }

  .not-found h1 {
    margin: 0 0 0.75rem;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .not-found p {
    margin: 0 0 1.5rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .not-found .cta-button,
  .brief-cta .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.85rem 2rem;
    border-radius: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.98rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s;
  }

  .not-found .cta-button:hover,
  .brief-cta .cta-button:hover {
    transform: translateY(-2px);
    background: var(--accent-dark);
  }

  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding: 2rem 0;
  }

  .site-footer p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-align: center;
  }
</style>
