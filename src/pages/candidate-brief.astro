---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
import "../styles/brief.css";

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://cal.com/furumconsulting/discovery-call";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Free Candidate Marketing Brief Generator"
      description="Upload a candidate's resume and instantly get an anonymized MPC campaign brief: positioning, selling angles, target companies, and ready-to-send outreach copy."
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/"><img src="/logo-light.png" alt="Furum Consulting" class="logo" /></a>
      </div>
    </header>

    <main class="page-shell">
      <section class="tool-section">
        <div class="container">
          <div class="tool-header">
            <p class="eyebrow-text">Free tool for staffing &amp; recruiting agencies</p>
            <h1>Turn Any Resume Into a Client-Winning Marketing Brief</h1>
            <p class="subheadline">
              Upload a candidate's resume and get an anonymized MPC campaign brief in
              about a minute: positioning, selling angles, target companies, and
              ready-to-send outreach copy.
            </p>
          </div>

          <div id="form-panel" class="form-card">
            <form id="brief-form" novalidate>
              <div class="form-row">
                <div class="form-field">
                  <label for="firstName">First name</label>
                  <input id="firstName" name="firstName" type="text" autocomplete="given-name" required maxlength="100" placeholder="Alex" />
                </div>
                <div class="form-field">
                  <label for="email">Work email</label>
                  <input id="email" name="email" type="email" autocomplete="email" required placeholder="alex@youragency.com" />
                </div>
              </div>

              <div class="form-field">
                <label for="resume">Candidate resume (PDF, max 5 MB)</label>
                <input id="resume" name="resume" type="file" accept="application/pdf,.pdf" required />
              </div>

              <p class="form-field form-honeypot" aria-hidden="true">
                <label for="website">Website</label>
                <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
              </p>
              <input type="hidden" name="loadedAt" id="loadedAt" value="" />

              <p id="form-error" class="form-error" hidden></p>

              <button class="cta-button" type="submit">Generate My Brief</button>
              <p class="consent-note">
                The resume is analyzed in memory and never stored. We'll email you a
                permanent link to your brief. No spam, unsubscribe anytime.
              </p>
            </form>
          </div>

          <div id="status-panel" class="status-panel" hidden>
            <span class="status-dot" aria-hidden="true"></span>
            <p id="status-message">Reading the resume&hellip;</p>
          </div>

          <div id="error-panel" class="error-panel" hidden>
            <p id="error-message"></p>
            <button id="retry-button" class="cta-button" type="button">Try Again</button>
          </div>

          <div id="brief-output" class="brief" aria-live="polite"></div>

          <div id="permalink-panel" class="permalink-panel no-print" hidden>
            <p>
              Saved. Your brief lives at
              <a id="permalink-anchor" href="/">this permanent link</a>
              and we've emailed it to you too.
            </p>
            <a id="pdf-download" class="pdf-button" href="/">Download PDF</a>
          </div>

          <aside id="cta-panel" class="brief-cta" hidden>
            <p>
              This is a preview of what we build for staffing agencies at scale: full
              MPC campaigns, target lists, and outbound infrastructure. Book 15 minutes.
            </p>
            <a class="cta-button" href={bookingUrl}>Book 15 Minutes</a>
          </aside>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Furum Consulting. All rights reserved.</p>
      </div>
    </footer>

    <script>
      import { initCopyButtons, parsePartialBrief, renderBrief } from "../lib/brief-render";

      const form = document.getElementById("brief-form") as HTMLFormElement;
      const formPanel = document.getElementById("form-panel") as HTMLElement;
      const formError = document.getElementById("form-error") as HTMLElement;
      const statusPanel = document.getElementById("status-panel") as HTMLElement;
      const statusMessage = document.getElementById("status-message") as HTMLElement;
      const errorPanel = document.getElementById("error-panel") as HTMLElement;
      const errorMessage = document.getElementById("error-message") as HTMLElement;
      const retryButton = document.getElementById("retry-button") as HTMLButtonElement;
      const output = document.getElementById("brief-output") as HTMLElement;
      const permalinkPanel = document.getElementById("permalink-panel") as HTMLElement;
      const permalinkAnchor = document.getElementById("permalink-anchor") as HTMLAnchorElement;
      const pdfAnchor = document.getElementById("pdf-download") as HTMLAnchorElement;
      const ctaPanel = document.getElementById("cta-panel") as HTMLElement;

      (document.getElementById("loadedAt") as HTMLInputElement).value = String(Date.now());
      initCopyButtons(document.body);

      const STAGES = [
        "Reading the resume…",
        "Identifying the strongest selling angles…",
        "Researching the target company profile…",
        "Writing the MPC outreach copy…",
        "Building the follow-up sequence…",
      ];
      let stageTimer: ReturnType<typeof setInterval> | undefined;

      function startStages() {
        let index = 0;
        statusMessage.textContent = STAGES[0];
        statusPanel.hidden = false;
        stageTimer = setInterval(() => {
          index = Math.min(index + 1, STAGES.length - 1);
          statusMessage.textContent = STAGES[index];
        }, 4000);
      }

      function stopStages() {
        clearInterval(stageTimer);
        statusPanel.hidden = true;
      }

      function showError(message: string) {
        stopStages();
        output.innerHTML = "";
        errorMessage.textContent = message;
        errorPanel.hidden = false;
      }

      retryButton.addEventListener("click", () => {
        errorPanel.hidden = true;
        formPanel.hidden = false;
        (document.getElementById("loadedAt") as HTMLInputElement).value = String(Date.now());
      });

      let rawText = "";
      let renderQueued = false;
      function scheduleRender() {
        if (renderQueued) return;
        renderQueued = true;
        setTimeout(() => {
          renderQueued = false;
          const partial = parsePartialBrief(rawText);
          if (partial && !partial.error) {
            output.innerHTML = renderBrief(partial);
          }
        }, 150);
      }

      function validate(): string | null {
        const firstName = (form.elements.namedItem("firstName") as HTMLInputElement).value.trim();
        const email = (form.elements.namedItem("email") as HTMLInputElement).value.trim();
        const file = (form.elements.namedItem("resume") as HTMLInputElement).files?.[0];
        if (!firstName) return "Please enter your first name.";
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) return "Please enter a valid email address.";
        if (!file) return "Please attach a resume PDF.";
        if (!(file.type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf")))
          return "The resume must be a PDF file.";
        if (file.size > 5 * 1024 * 1024) return "The resume must be under 5 MB.";
        return null;
      }

      async function handleStream(response: Response) {
        const reader = response.body!.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        let finished = false;

        const handleEvent = (eventName: string, dataRaw: string) => {
          let data: Record<string, string> = {};
          try {
            data = JSON.parse(dataRaw);
          } catch {
            return;
          }
          if (eventName === "meta") {
            if (data.url) permalinkAnchor.href = data.url;
            if (data.pdfUrl) pdfAnchor.href = data.pdfUrl;
          } else if (eventName === "delta" && typeof data.text === "string") {
            rawText += data.text;
            scheduleRender();
          } else if (eventName === "done") {
            finished = true;
            stopStages();
            const finalBrief = parsePartialBrief(rawText);
            if (finalBrief) output.innerHTML = renderBrief(finalBrief);
            permalinkPanel.hidden = false;
            ctaPanel.hidden = false;
          } else if (eventName === "error") {
            finished = true;
            showError(data.message || "Something went wrong. Please try again.");
          }
        };

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const events = buffer.split("\n\n");
          buffer = events.pop() ?? "";
          for (const chunk of events) {
            let eventName = "message";
            const dataLines: string[] = [];
            for (const line of chunk.split("\n")) {
              if (line.startsWith("event: ")) eventName = line.slice(7).trim();
              else if (line.startsWith("data: ")) dataLines.push(line.slice(6));
            }
            if (dataLines.length) handleEvent(eventName, dataLines.join("\n"));
          }
        }
        if (!finished) {
          showError("The connection dropped mid-generation. Please try again.");
        }
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const validationError = validate();
        if (validationError) {
          formError.textContent = validationError;
          formError.hidden = false;
          return;
        }
        formError.hidden = true;
        formPanel.hidden = true;
        errorPanel.hidden = true;
        rawText = "";
        output.innerHTML = "";
        startStages();

        try {
          const response = await fetch("/api/generate-brief", {
            method: "POST",
            body: new FormData(form),
          });
          if (!response.ok || response.headers.get("content-type")?.includes("json")) {
            const payload = await response.json().catch(() => null);
            showError(payload?.error || "Something went wrong. Please try again.");
            return;
          }
          await handleStream(response);
        } catch (error) {
          console.error(error);
          showError("Couldn't reach the server. Check your connection and try again.");
        }
      });
    </script>
  </body>
</html>

<style>
  .container {
    width: min(100% - 2rem, 1120px);
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    overflow: visible;
  }

  .logo {
    height: 7.5rem;
    width: auto;
    margin-left: -0.75rem;
    object-fit: contain;
  }

  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .tool-section {
    padding: 3rem 0 5rem;
  }

  .tool-header {
    max-width: 760px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .eyebrow-text {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.45rem 0.9rem;
    border-radius: 0.4rem;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-weight: 700;
    font-size: clamp(1.9rem, 3.6vw, 2.9rem);
    line-height: 1.15;
  }

  .subheadline {
    max-width: 640px;
    margin: 1rem auto 0;
    color: var(--text-muted);
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.55;
  }

  .form-card {
    max-width: 620px;
    margin: 0 auto;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 560px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-field {
    margin-bottom: 1rem;
  }

  .form-field label {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--text-primary);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .form-field input[type="text"],
  .form-field input[type="email"] {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--page-bg);
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  .form-field input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .form-field input[type="file"] {
    width: 100%;
    padding: 0.55rem;
    border: 1px dashed var(--accent-border);
    border-radius: 0.5rem;
    background: var(--page-bg);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    height: 1px;
    overflow: hidden;
  }

  .form-error {
    margin: 0 0 1rem;
    color: hsl(0 65% 45%);
    font-size: 0.9rem;
  }

  .form-card .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3.25rem;
    padding: 0.85rem 2rem;
    border: none;
    border-radius: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.98rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s, background 0.2s;
  }

  .form-card .cta-button:hover {
    transform: translateY(-2px);
    background: var(--accent-dark);
  }

  .consent-note {
    margin: 0.9rem 0 0;
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.5;
    text-align: center;
  }

  .status-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    max-width: 620px;
    margin: 1.5rem auto;
    padding: 1rem 1.4rem;
    border: 1px solid var(--accent-border);
    border-radius: 0.8rem;
    background: var(--accent-bg);
  }

  .status-panel p {
    margin: 0;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .status-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: var(--accent);
    animation: pulse 1.2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.35; transform: scale(0.75); }
  }

  .error-panel {
    max-width: 620px;
    margin: 1.5rem auto;
    padding: 1.5rem;
    border: 1px solid hsl(0 50% 80%);
    border-radius: 0.8rem;
    background: hsl(0 60% 97%);
    text-align: center;
  }

  .error-panel p {
    margin: 0 0 1rem;
    color: hsl(0 55% 40%);
    line-height: 1.5;
  }

  .error-panel .cta-button,
  .permalink-panel a {
    color: var(--accent);
  }

  .error-panel .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.6rem;
    border: 1px solid var(--accent-border);
    border-radius: 0.55rem;
    background: var(--page-bg);
    font-weight: 700;
    cursor: pointer;
  }

  .permalink-panel {
    max-width: 780px;
    margin: 2rem auto 0;
    padding: 1rem 1.4rem;
    border: 1px solid var(--accent-border);
    border-radius: 0.8rem;
    background: var(--accent-bg);
  }

  .permalink-panel p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .permalink-panel a {
    font-weight: 700;
  }

  .permalink-panel .pdf-button {
    margin-top: 0.85rem;
    color: #fff;
  }

  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding: 2rem 0;
  }

  .site-footer p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-align: center;
  }

  #brief-output {
    margin-top: 2rem;
  }
</style>
