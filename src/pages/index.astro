---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main class="page-shell">
      <section class="vsl-hero noise-bg">
        <div class="grid-bg"></div>
        <div class="glow glow-top"></div>
        <div class="glow glow-bottom"></div>

        <div class="container">
          <div class="hero-copy">
            <p class="eyebrow">For staffing and recruiting agency owners</p>

            <h1>
              Get 24-36 New Clients by This Time Next Year
              <span>On a Pure Pay-Per-Call Basis.</span>
            </h1>

            <p class="subheadline">
              Watch the short training below to see how our MPC Demand Engine
              turns Most Placeable Candidates into qualified hiring manager
              conversations, without cold calling, chasing, or hiring a BD person.
            </p>
          </div>

          <div class="video-shell" aria-label="Video sales letter">
            <div class="video-frame">
              <div class="video-topbar">
                <span></span>
                <span></span>
                <span></span>
              </div>

              <div class="video-content">
                <button class="play-button" type="button" aria-label="Play video">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z"></path>
                  </svg>
                </button>
                <p class="video-label">Private VSL</p>
                <p class="video-title">How to book qualified operator conversations using candidates your market already wants</p>
              </div>
            </div>
          </div>

          <div class="cta-block">
            <a class="cta-button" href="#calendar">
              Book Your Discovery Call
            </a>
            <p>Only pay when qualified hiring manager calls are booked.</p>
          </div>

          <div class="proof-grid" aria-label="What the system includes">
            <div class="proof-card">
              <strong>MPC Profiles</strong>
              <span>Package your strongest candidates around real operator pain.</span>
            </div>
            <div class="proof-card">
              <strong>Hiring Intent</strong>
              <span>Find companies already showing signs of active demand.</span>
            </div>
            <div class="proof-card">
              <strong>Reply Handling</strong>
              <span>Manage every response and turn interest into booked meetings.</span>
            </div>
          </div>

          <section id="calendar" class="calendar-section" aria-label="Book a discovery call">
            <div class="calendar-copy">
              <p class="calendar-eyebrow">Ready to build your pipeline?</p>
              <h2>Schedule Your Discovery Call Below</h2>
            </div>
            <div class="calendar-card">
              <div id="cal-embed" class="cal-embed"></div>
            </div>
          </section>
        </div>
      </section>
    </main>

    <script>
      function getCalTheme(): "light" | "dark" {
        const html = document.documentElement;
        if (html.classList.contains("light")) return "light";
        if (html.classList.contains("dark")) return "dark";
        return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      }

      (function (C: any, A: string, L: string) {
        const p = function (a: any, ar: IArguments) {
          a.q.push(ar);
        };
        const d = C.document;
        C.Cal = C.Cal || function () {
          const cal = C.Cal;
          const ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () {
              p(api, arguments);
            };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      const calTheme = getCalTheme();
      (window as any).Cal("init", "discovery-call", { origin: "https://app.cal.com" });
      (window as any).Cal.ns["discovery-call"]("inline", {
        elementOrSelector: "#cal-embed",
        calLink: "furumconsulting/discovery-call",
        config: {
          theme: calTheme,
          layout: "month_view"
        }
      });
      (window as any).Cal.ns["discovery-call"]("ui", {
        theme: calTheme,
        styles: {
          branding: {
            brandColor: "#2d5d52"
          }
        },
        hideEventTypeDetails: false
      });
    </script>
  </body>
</html>

<style>
  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .vsl-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 1.55rem 0 4rem;
    background: var(--page-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.7;
  }

  .glow {
    position: absolute;
    border-radius: 999px;
    background: var(--accent-bg-strong);
    filter: blur(90px);
    pointer-events: none;
  }

  .glow-top {
    top: -8rem;
    left: 50%;
    width: 34rem;
    height: 18rem;
    transform: translateX(-50%);
  }

  .glow-bottom {
    right: -10rem;
    bottom: 5rem;
    width: 24rem;
    height: 24rem;
    opacity: 0.7;
  }

  .container {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, 1320px);
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 1240px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.9rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(2.35rem, 4.7vw, 5.65rem);
    font-weight: 700;
    line-height: 0.9;
  }

  h1 span {
    display: block;
    color: var(--accent);
  }

  .subheadline {
    max-width: 860px;
    margin: 1rem auto 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.55;
  }

  .video-shell {
    max-width: 1040px;
    margin: 1.55rem auto 0;
  }

  .video-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--accent-border);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 50% 0%, var(--accent-bg-strong), transparent 42%),
      linear-gradient(145deg, var(--surface2), var(--surface));
    box-shadow: 0 24px 80px var(--shadow-color), 0 0 48px var(--glow);
    aspect-ratio: 16 / 9;
  }

  .video-topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    gap: 0.45rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(0, 0, 0, 0.16);
  }

  .video-topbar span {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: var(--text-dim);
    opacity: 0.65;
  }

  .video-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .play-button {
    display: grid;
    place-items: center;
    width: clamp(4.5rem, 10vw, 7rem);
    height: clamp(4.5rem, 10vw, 7rem);
    margin-bottom: 1.4rem;
    border: 1px solid var(--accent-hover-border);
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 0 46px var(--glow);
    transition: transform 0.2s, background 0.2s;
  }

  .play-button:hover {
    transform: scale(1.04);
    background: var(--accent-dark);
  }

  .play-button svg {
    width: 42%;
    height: 42%;
    margin-left: 0.25rem;
    fill: currentColor;
  }

  .video-label {
    margin: 0 0 0.45rem;
    color: var(--green-badge-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .video-title {
    max-width: 34rem;
    margin: 0;
    color: var(--text-secondary);
    font-size: clamp(1rem, 2vw, 1.35rem);
    line-height: 1.35;
  }

  .cta-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin: 2rem auto 0;
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.5rem;
    padding: 0.95rem 2rem;
    border-radius: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: transform 0.2s, background 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    background: var(--accent-dark);
  }

  .cta-block p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.9rem;
    max-width: 1040px;
    margin: 2.2rem auto 0;
  }

  .proof-card {
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--card-hover-bg);
    text-align: center;
  }

  .proof-card strong {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.2rem;
  }

  .proof-card span {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .calendar-section {
    max-width: 1040px;
    margin: 3rem auto 0;
    scroll-margin-top: 1rem;
  }

  .calendar-copy {
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .calendar-eyebrow {
    margin: 0 0 0.55rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .calendar-copy h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1;
  }

  .calendar-card {
    overflow: hidden;
    border: 1px solid var(--accent-border);
    border-radius: 1rem;
    background: var(--surface2);
    box-shadow: 0 18px 60px var(--shadow-color);
  }

  .cal-embed {
    width: 100%;
    min-height: 680px;
  }

  @media (min-width: 760px) {
    .vsl-hero {
      padding-top: 2rem;
    }

    .brand {
      margin-bottom: 0;
    }

    .proof-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .video-frame {
      border-radius: 0.75rem;
    }

    .video-content {
      padding-top: 3.6rem;
    }

    .calendar-section {
      margin-top: 2.25rem;
    }

    .cal-embed {
      min-height: 720px;
    }

    .cta-button {
      width: 100%;
      max-width: 24rem;
      font-size: 0.88rem;
    }

    .eyebrow {
      max-width: 20rem;
      padding: 0.45rem 0.75rem;
      font-size: 0.62rem;
      line-height: 1.35;
      letter-spacing: 0.08em;
    }
  }
</style>
