---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero-section noise-bg">
        <div class="grid-bg"></div>
        <div class="glow glow-top"></div>
        <div class="glow glow-bottom"></div>

        <div class="container">
          <div class="hero-copy">
            <p class="eyebrow">For staffing and recruiting agency owners</p>
            <h1>
              Get 24-36 New Clients by This Time Next Year
              <span>On a Pure Pay-Per-Call Basis.</span>
            </h1>
            <p class="subheadline">
              We build the outbound infrastructure, MPC messaging, hiring-intent lists,
              and reply handling system that places qualified hiring manager
              conversations on your calendar without cold calling, chasing, or hiring a BD person.
            </p>

            <div class="cta-row">
              <a class="cta-button" href="/booking">Book Your Discovery Call</a>
              <p>Only pay when qualified hiring manager calls are booked.</p>
            </div>

            <div class="trust-row" aria-label="Offer highlights">
              <span>DFY MPC Demand Engine</span>
              <span>Qualified operator conversations</span>
              <span>Performance-based model</span>
            </div>
          </div>
        </div>
      </section>

    </main>
  </body>
</html>

<style>
  .page-shell {
    min-height: 100vh;
    background: var(--page-bg);
  }

  .hero-section {
    position: relative;
    overflow: hidden;
  }

  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
    background: var(--page-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.7;
  }

  .glow {
    position: absolute;
    border-radius: 999px;
    background: var(--accent-bg-strong);
    filter: blur(90px);
    pointer-events: none;
  }

  .glow-top {
    top: -8rem;
    left: 50%;
    width: 34rem;
    height: 18rem;
    transform: translateX(-50%);
  }

  .glow-bottom {
    right: -10rem;
    bottom: 5rem;
    width: 24rem;
    height: 24rem;
    opacity: 0.7;
  }

  .container {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 1rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-weight: 700;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 5.5vw, 6.4rem);
    line-height: 0.92;
  }

  h1 span {
    display: block;
    color: var(--accent);
  }

  .subheadline {
    max-width: 850px;
    margin: 1.15rem auto 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.55;
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin: 2rem auto 0;
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.5rem;
    padding: 0.95rem 2rem;
    border-radius: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: transform 0.2s, background 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    background: var(--accent-dark);
  }

  .cta-row p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .trust-row span {
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--card-hover-bg);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 560px) {
    .hero-section {
      min-height: auto;
      padding: 3rem 0 4rem;
    }

    .eyebrow {
      max-width: 20rem;
      padding: 0.45rem 0.75rem;
      font-size: 0.62rem;
      line-height: 1.35;
      letter-spacing: 0.08em;
    }

    .cta-button {
      width: 100%;
      max-width: 24rem;
      font-size: 0.86rem;
    }

  }
</style>
