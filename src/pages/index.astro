---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import SocialProofSection from '../components/landing/SocialProofSection.astro';
import ProblemSection from '../components/landing/ProblemSection.astro';
import MethodologySection from '../components/landing/MethodologySection.astro';
import ServicesSection from '../components/landing/ServicesSection.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import CTASection from '../components/landing/CTASection.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<HeroSection />
			<SocialProofSection />
			<ProblemSection />
			<MethodologySection />
			<ServicesSection />
			<FAQSection />
			<CTASection />
		</main>
		<Footer />
	</body>
</html>
