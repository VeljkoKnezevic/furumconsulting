---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <img src="/logo-light.png" alt="Furum Consulting" class="logo" />
      </div>
    </header>

    <main class="page-shell">
      <!-- Hero + Step 1: headline and video, kept tight so both sit above the fold -->
      <section class="hero-section">
        <div class="container">
          <div class="hero-copy">
            <p class="eyebrow-text">For staffing and recruiting agency owners</p>
            <h1>
              Discover How We Can <span class="u">Guarantee</span> You
              <span>20-30 New Clients</span> In <span>10 Months or Less...</span>
            </h1>
          </div>

          <p class="step-heading"><span>Step 1 of 2:</span> Watch Video</p>

          <div class="video-frame shadow-medium">
            <div id="vidalytics_embed_8GoihHVYaY4zw8qH" style="width: 100%; position: relative; padding-top: 56.25%;"></div>
          </div>
        </div>
      </section>

      <!-- Step 2: Book the call -->
      <section id="book" class="step-section">
        <div class="container">
          <div class="step-header">
            <h2 class="step-heading"><span>Step 2 of 2:</span> Schedule Your Discovery Call</h2>
            <p>
              A low-pressure call designed to learn about your agency and see
              whether we're a good fit to work together.
            </p>
          </div>

          <div class="calendar-card shadow-medium">
            <div id="cal-embed" class="cal-embed"></div>
          </div>
        </div>
      </section>

      <!-- ROI calculator -->
      <section class="calc-section">
        <div class="container">
          <div class="section-header">
            <p class="step-inline"><span>Your numbers</span></p>
            <h2>What Would This Do for Your Agency?</h2>
            <p>Two inputs. See what the system would produce for your agency.</p>
          </div>

          <div class="calc-panel shadow-medium">
            <div class="calc-inputs">
              <div class="calc-field">
                <label for="calc-revenue">
                  Average revenue per client in the first year
                  <output id="calc-revenue-out">$30,000</output>
                </label>
                <input id="calc-revenue" type="range" min="5000" max="150000" step="1000" value="30000" />
              </div>
              <div class="calc-field">
                <label for="calc-close">
                  Close rate from calls
                  <output id="calc-close-out">20%</output>
                </label>
                <input id="calc-close" type="range" min="5" max="50" step="1" value="20" />
              </div>
            </div>

            <div class="calc-results" aria-live="polite">
              <div class="calc-result">
                <p>New clients / month</p>
                <strong id="calc-clients">2.1</strong>
              </div>
              <div class="calc-result">
                <p>New client revenue / month</p>
                <strong id="calc-revenue-result">$63,360</strong>
              </div>
              <div class="calc-result calc-result--roi">
                <p>Return on investment</p>
                <strong id="calc-roi">9x</strong>
              </div>
            </div>

            <p class="calc-note">Projections assume conservative campaign performance.</p>
          </div>
        </div>
      </section>

      <!-- What you'll learn -->
      <section class="learn-section">
        <div class="container">
          <div class="section-header">
            <p class="step-inline"><span>On the call</span></p>
            <h2>What You&rsquo;ll Learn</h2>
          </div>

          <div class="learn-grid">
            <article class="learn-card">
              <span class="learn-number">01</span>
              <strong>Whether you&rsquo;re a fit</strong>
              <p>If your niche and candidate bench support a pay-per-call model, and if not, why.</p>
            </article>
            <article class="learn-card">
              <span class="learn-number">02</span>
              <strong>How the system is built</strong>
              <p>How the MPC messaging, lists, and outbound infrastructure are engineered for your market.</p>
            </article>
            <article class="learn-card">
              <span class="learn-number">03</span>
              <strong>What to expect</strong>
              <p>A realistic view of pipeline, timeline, and results over the next 90 days.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- What's included -->
      <section class="offer-section">
        <div class="container">
          <div class="offer-panel shadow-strong">
            <div class="section-header">
              <p class="step-inline"><span>The offer</span></p>
              <h2>What&rsquo;s Included</h2>
              <p>
                A done-for-you system built and run for your agency. Not a
                course, not software you have to figure out yourself.
              </p>
            </div>

            <ul class="offer-list">
              <li>Outbound infrastructure setup &amp; deliverability management</li>
              <li>MPC-led messaging &amp; offer positioning for your niche</li>
              <li>Hiring-intent lists sourced and refreshed weekly</li>
              <li>Reply handling and qualification, so only booked calls reach you</li>
              <li>Performance-based, pay-per-call pricing</li>
            </ul>

            <div class="offer-cta">
              <a class="cta-button" href="#book">Book Your Free Discovery Call</a>
              <p>Only pay when qualified hiring manager calls are booked.</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Furum Consulting. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline type="text/javascript">
      (function (v, i, d, a, l, y, t, c, s) {
        y = '_' + d.toLowerCase(); c = d + 'L'; if (!v[d]) { v[d] = {}; } if (!v[c]) { v[c] = {}; } if (!v[y]) { v[y] = {}; } var vl = 'Loader', vli = v[y][vl], vsl = v[c][vl + 'Script'], vlf = v[c][vl + 'Loaded'], ve = 'Embed';
        if (!vsl) {
          vsl = function (u, cb) {
            if (t) { cb(); return; } s = i.createElement("script"); s.type = "text/javascript"; s.async = 1; s.src = u;
            if (s.readyState) { s.onreadystatechange = function () { if (s.readyState === "loaded" || s.readyState == "complete") { s.onreadystatechange = null; vlf = 1; cb(); } }; } else { s.onload = function () { vlf = 1; cb(); }; }
            i.getElementsByTagName("head")[0].appendChild(s);
          };
        }
        vsl(l + 'loader.min.js', function () { if (!vli) { var vlc = v[c][vl]; vli = new vlc(); } vli.loadScript(l + 'player.min.js', function () { var vec = v[d][ve]; t = new vec(); t.run(a); }); });
      })(window, document, 'Vidalytics', 'vidalytics_embed_8GoihHVYaY4zw8qH', 'https://fast.vidalytics.com/embeds/2rtPO8Ua/8GoihHVYaY4zw8qH/');
    </script>

    <script>
      (function (C: any, A: string, L: string) {
        const p = function (a: any, ar: IArguments) {
          a.q.push(ar);
        };
        const d = C.document;
        C.Cal = C.Cal || function () {
          const cal = C.Cal;
          const ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () {
              p(api, arguments);
            };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      (window as any).Cal("init", "discovery-call", { origin: "https://app.cal.com" });
      (window as any).Cal.ns["discovery-call"]("inline", {
        elementOrSelector: "#cal-embed",
        calLink: "furumconsulting/discovery-call",
        config: {
          theme: "light",
          layout: "month_view"
        }
      });
      (window as any).Cal.ns["discovery-call"]("ui", {
        theme: "light",
        styles: {
          branding: {
            brandColor: "#2d5d52"
          }
        },
        hideEventTypeDetails: false
      });
    </script>

    <script>
      // ROI calculator. Volume and pricing are fixed internally and never rendered.
      // Pricing model: base fee + 2% of avg first-year client revenue per show.
      const EMAILS_PER_DAY = 1000;
      const SENDING_DAYS = 22;
      const REPLY_RATE = 0.015;
      const POSITIVE_RATE = 0.1;
      const BOOK_RATE = 0.4;
      const SHOW_RATE = 0.8;
      const BASE_FEE = 500;
      const REV_SHARE_PER_SHOW = 0.02;

      const revenueInput = document.getElementById("calc-revenue") as HTMLInputElement;
      const closeInput = document.getElementById("calc-close") as HTMLInputElement;
      const revenueOut = document.getElementById("calc-revenue-out") as HTMLOutputElement;
      const closeOut = document.getElementById("calc-close-out") as HTMLOutputElement;
      const clientsEl = document.getElementById("calc-clients") as HTMLElement;
      const revenueResultEl = document.getElementById("calc-revenue-result") as HTMLElement;
      const roiEl = document.getElementById("calc-roi") as HTMLElement;

      function update() {
        const avgRevenue = Number(revenueInput.value);
        const closeRate = Number(closeInput.value) / 100;

        const emails = EMAILS_PER_DAY * SENDING_DAYS;
        const replies = emails * REPLY_RATE;
        const leads = replies * POSITIVE_RATE;
        const calls = leads * BOOK_RATE;
        const shows = calls * SHOW_RATE;
        const clients = shows * closeRate;
        const revenue = clients * avgRevenue;
        const cost = BASE_FEE + REV_SHARE_PER_SHOW * avgRevenue * shows;

        revenueOut.textContent = `$${avgRevenue.toLocaleString("en-US")}`;
        closeOut.textContent = `${closeInput.value}%`;
        clientsEl.textContent = clients.toFixed(1);
        revenueResultEl.textContent = `$${Math.round(revenue).toLocaleString("en-US")}`;
        roiEl.textContent = `${Math.round(revenue / cost)}x`;
      }

      revenueInput.addEventListener("input", update);
      closeInput.addEventListener("input", update);
      update();
    </script>
  </body>
</html>

<style>
  .container {
    width: min(100% - 2rem, 1120px);
    margin: 0 auto;
  }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    overflow: visible;
  }

  /* The source PNG has heavy transparent padding around the mark, so the
     rendered box has to be oversized relative to the header bar to make the
     logo itself read at a normal size; the negative margin removes the
     matching whitespace on the left edge. */
  .logo {
    height: 7.5rem;
    width: auto;
    margin-left: -0.75rem;
    object-fit: contain;
  }

  /* Page shell */
  .page-shell {
    background: var(--page-bg);
  }

  /* Hero + Step 1 */
  .hero-section {
    padding: 2rem 0 3rem;
  }

  .hero-copy {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow-text {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.45rem 0.9rem;
    border-radius: 0.4rem;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-weight: 700;
    letter-spacing: 0;
    font-size: clamp(1.9rem, 3.6vw, 2.9rem);
    line-height: 1.15;
  }

  h1 span {
    color: var(--accent);
  }

  h1 span.u {
    text-decoration: underline;
    text-decoration-thickness: 0.09em;
    text-underline-offset: 0.14em;
  }

  .step-heading {
    margin: 2.25rem 0 1.25rem;
    text-align: center;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .step-heading span {
    color: var(--accent);
  }

  .step-header .step-heading {
    margin: 0;
  }

  .step-inline {
    margin: 0 0 1rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .step-inline span {
    color: var(--accent);
    font-weight: 700;
  }

  /* Step 2 section */
  .step-section {
    padding: 4.5rem 0;
    border-top: 1px solid var(--border-subtle);
    background: var(--surface);
  }

  .step-header,
  .section-header {
    max-width: 720px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-weight: 700;
    letter-spacing: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .step-header p,
  .section-header p {
    margin: 0.85rem auto 0;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* Video */
  .video-frame {
    max-width: 700px;
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface2);
  }

  /* Calendar */
  .calendar-card {
    max-width: 900px;
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid var(--accent-border);
    border-radius: 1rem;
    background: var(--page-bg);
  }

  .cal-embed {
    width: 100%;
    min-height: 680px;
  }

  /* ROI calculator */
  .calc-section {
    padding: 4.5rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .calc-panel {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--page-bg);
  }

  .calc-inputs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }

  .calc-field label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .calc-field output {
    color: var(--accent);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.2rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .calc-field input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .calc-results {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  .calc-result {
    padding: 1.5rem;
    border: 1px solid var(--accent-border);
    border-radius: 0.8rem;
    background: var(--accent-bg);
    text-align: center;
  }

  .calc-result p {
    margin: 0 0 0.4rem;
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .calc-result strong {
    color: var(--accent);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    line-height: 1;
  }

  .calc-result--roi {
    border-color: var(--accent);
    background: var(--accent);
  }

  .calc-result--roi p {
    color: rgba(255, 255, 255, 0.8);
  }

  .calc-result--roi strong {
    color: #fff;
  }

  .calc-note {
    max-width: 640px;
    margin: 1.75rem auto 0;
    color: var(--text-dim);
    font-size: 0.8rem;
    line-height: 1.55;
    text-align: center;
  }

  @media (min-width: 720px) {
    .calc-inputs {
      grid-template-columns: 1fr 1fr;
    }

    .calc-results {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Learn grid */
  .learn-section {
    padding: 5rem 0;
  }

  .learn-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .learn-card {
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    background: var(--page-bg);
  }

  .learn-number {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--number-color);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1;
  }

  .learn-card strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-display, "Clash Grotesk", system-ui, sans-serif);
    font-size: 1.15rem;
  }

  .learn-card p {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* Offer */
  .offer-section {
    padding: 0 0 5.5rem;
  }

  .offer-panel {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--surface);
  }

  .offer-list {
    max-width: 620px;
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .offer-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--text-secondary);
    font-size: 1.02rem;
    line-height: 1.5;
  }

  .offer-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .offer-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin: 2.5rem auto 0;
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.5rem;
    padding: 0.95rem 2.25rem;
    border-radius: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: transform 0.2s, background 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    background: var(--accent-dark);
  }

  .offer-cta p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding: 2rem 0;
  }

  .site-footer p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-align: center;
  }

  @media (min-width: 800px) {
    .learn-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .hero-section {
      padding: 1.25rem 0 2.25rem;
    }

    .step-section {
      padding: 3.5rem 0;
    }

    .offer-panel {
      padding: 2.25rem 1.5rem;
    }

    .cal-embed {
      min-height: 720px;
    }

    .cta-button {
      width: 100%;
      max-width: 24rem;
    }
  }
</style>
