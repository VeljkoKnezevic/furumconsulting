---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	keywords?: string;
	type?: string;
	noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = '/logo-light.png',
	keywords = "AI gym lead follow-up, gym appointment booking system, fitness studio lead nurture, AI voice follow-up gyms, automated gym appointments, gym member acquisition, qualified appointments for gyms, fitness business growth, AI lead conversion",
	type = "website",
	noindex = false
} = Astro.props;

// Full title with branding
const fullTitle = title.includes("Furum Consulting") ? title : `${title} | Furum Consulting`;

// Site info for schema
const siteUrl = Astro.site?.toString() || "https://furumconsulting.com";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="dark light" />

<!-- Theme: prevent flash by applying stored preference before paint -->
<script is:inline>
(function() {
  var t = localStorage.getItem('theme');
  if (t === 'light') document.documentElement.classList.add('light');
  else if (t === 'dark') document.documentElement.classList.add('dark');
})();
</script>

<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/Apple 180x180.png" />
<meta name="generator" content={Astro.generator} />

<!-- SEO Meta Tags -->
<meta name="keywords" content={keywords} />
<meta name="author" content="Furum Consulting" />
<meta name="language" content="English" />
<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
<meta name="googlebot" content={noindex ? "noindex,nofollow" : "index,follow"} />

<!-- Fonts: Clash Grotesk + Satoshi from Fontshare -->
<link rel="preconnect" href="https://api.fontshare.com" />
<link href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@600,700&f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />

<!-- Iconify Icons -->
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Furum Consulting" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.url)} />
<meta name="twitter:creator" content="@furumconsulting" />

<!-- Organization Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "Furum Consulting",
	"url": siteUrl,
	"logo": new URL("/logo-light.png", siteUrl),
	"description": "AI-powered appointment booking system for gyms and fitness studios. 30 qualified appointments in 30 days on a pay-per-appointment basis. Your leads followed up 24/7 without your staff picking up the phone.",
	"foundingDate": "2024",
	"contactPoint": {
		"@type": "ContactPoint",
		"contactType": "Sales",
		"url": `${siteUrl}#book-call`
	},
	"sameAs": [
		"https://www.linkedin.com/company/furum-consulting"
	]
})} />

<!-- Service Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "AI-Powered Gym Appointment Booking System",
	"provider": {
		"@type": "Organization",
		"name": "Furum Consulting",
		"url": siteUrl
	},
	"areaServed": {
		"@type": "Place",
		"name": "Worldwide"
	},
	"description": "AI-powered appointment system for gym and fitness studio owners. 30 qualified appointments in 30 days on a pay-per-appointment basis. Leads followed up 24/7 via AI voice and text.",
	"offers": {
		"@type": "Offer",
		"url": `${siteUrl}#book-call`,
		"availability": "https://schema.org/InStock"
	}
})} />
