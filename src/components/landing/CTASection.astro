---
// CTASection - Final call to action with Cal.com calendar embed
---

<section class="cta-section" id="booking">
  <div class="container">
    <div class="cta-grid">
      <!-- Content -->
      <div class="content">
        <h2>Ready to own the <span class="highlight">dominant</span> gym in your city?</h2>
        <p class="description">
          We only partner with one gym per zip code to avoid conflict of interest. Check if your territory is still available.
        </p>

        <div class="availability">
          <div class="pulse"></div>
          <span>3 Spots remaining for Q3 Partnership</span>
        </div>

        <div class="benefit">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="benefit-title">Free 30-Min Strategy Call</p>
            <p class="benefit-sub">Worth $297 - yours free today</p>
          </div>
        </div>
      </div>

      <!-- Calendar Card -->
      <div class="calendar-card">
        <h3>Secure Your Growth Audit</h3>
        <div id="cal-embed" class="cal-embed"></div>
      </div>
    </div>
  </div>

  <!-- Background accent -->
  <div class="bg-accent"></div>
</section>

<script>
  // Cal.com embed
  (function (C, A, L) {
    let p = function (a: any, ar: any) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window as any, "https://app.cal.com/embed/embed.js", "init");

  (window as any).Cal("init", "discovery-call", { origin: "https://app.cal.com" });
  (window as any).Cal.ns["discovery-call"]("inline", {
    elementOrSelector: "#cal-embed",
    calLink: "furumconsulting/discovery-call",
    config: {
      layout: "month_view",
      useSlotsViewOnSmallScreen: "true"
    }
  });
  (window as any).Cal.ns["discovery-call"]("ui", {
    hideEventTypeDetails: false,
    layout: "month_view"
  });
</script>

<style>
  .cta-section {
    position: relative;
    padding: 6rem 0;
    background: hsl(var(--cream));
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .cta-section {
      padding: 8rem 0;
    }
  }

  .container {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cta-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  /* Content */
  .content h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .highlight {
    color: hsl(var(--gold));
    text-decoration: underline;
    text-decoration-thickness: 4px;
    text-underline-offset: 8px;
  }

  .description {
    font-size: 1.25rem;
    color: hsl(var(--foreground) / 0.8);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .pulse {
    width: 0.75rem;
    height: 0.75rem;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.2);
    }
  }

  .availability span {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .benefit {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .benefit-icon {
    width: 3rem;
    height: 3rem;
    background: hsl(var(--forest) / 0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: hsl(var(--forest));
  }

  .benefit-title {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .benefit-sub {
    font-size: 0.75rem;
    color: hsl(var(--forest) / 0.6);
  }

  /* Calendar Card */
  .calendar-card {
    background: white;
    padding: 2.5rem;
    box-shadow: 0 25px 50px -12px hsl(var(--forest) / 0.15);
    border: 1px solid hsl(var(--forest) / 0.05);
  }

  .calendar-card h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  /* Cal.com embed container */
  .cal-embed {
    min-height: 500px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .cal-embed {
      min-height: 550px;
    }
  }

  /* Background accent */
  .bg-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: hsl(var(--forest) / 0.03);
    z-index: 0;
    pointer-events: none;
  }
</style>
