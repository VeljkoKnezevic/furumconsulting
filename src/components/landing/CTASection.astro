---
// CTASection - Final CTA with Cal.com calendar embed
// Cal.com theme dynamically matches system preference
---

<section id="book-call" class="cta-section">
  <div class="grid-bg"></div>
  <div class="container">
    <div class="content-wrapper">
      <div class="section-header">
        <div class="availability-badge">
          <span class="pulse-dot"></span>
          <span>Limited Availability</span>
        </div>

        <h2>
          Ready to Turn Every Lead<br/>Into a <span class="dim">Booked Appointment?</span>
        </h2>

        <p class="cta-description">
          Book a complimentary strategy call. We'll look at your current ad performance, show you how many leads you're losing to slow follow-up, and map out how our AI system would work for your gym. Your trial campaign is pay-per-appointment only, so there's zero risk to try.
        </p>
      </div>

      <div class="calendar-card">
        <div id="cal-embed" class="cal-embed"></div>
      </div>

      <div class="cta-info">
        <div class="info-item">
          <iconify-icon icon="lucide:clock" class="info-icon"></iconify-icon>
          <span>45 minutes</span>
        </div>
        <div class="info-item">
          <iconify-icon icon="lucide:video" class="info-icon"></iconify-icon>
          <span>Google Meet</span>
        </div>
        <div class="info-item">
          <iconify-icon icon="lucide:shield" class="info-icon"></iconify-icon>
          <span>No obligation</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Detect current theme for Cal.com embed
  function getCalTheme(): string {
    const html = document.documentElement;
    if (html.classList.contains('dark')) return 'dark';
    if (html.classList.contains('light')) return 'light';
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }

  const calTheme = getCalTheme();

  // Cal.com embed
  (function (C, A, L) {
    let p = function (a: any, ar: any) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window as any, "https://app.cal.com/embed/embed.js", "init");

  (window as any).Cal("init", "discovery-call", { origin: "https://app.cal.com" });
  (window as any).Cal.ns["discovery-call"]("inline", {
    elementOrSelector: "#cal-embed",
    calLink: "furumconsulting/discovery-call",
    config: {
      theme: calTheme,
      layout: "month_view"
    }
  });
  (window as any).Cal.ns["discovery-call"]("ui", {
    theme: calTheme,
    styles: { branding: { brandColor: "#2d5d52" } },
    hideEventTypeDetails: false
  });
</script>

<style>
  .cta-section {
    position: relative;
    padding: 6rem 0;
    background: var(--surface);
  }

  @media (min-width: 1024px) {
    .cta-section { padding: 8rem 0; }
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 2rem; }
  }

  .content-wrapper {
    max-width: 56rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    margin-bottom: 2rem;
  }

  .pulse-dot {
    width: 0.5rem; height: 0.5rem;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .availability-badge span:last-child {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
  }

  .section-header h2 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .dim { color: var(--text-dim); }

  .cta-description {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 42rem;
    margin: 0 auto;
  }

  .calendar-card {
    background: var(--surface2);
    border-radius: 1rem;
    border: 1px solid var(--border);
    box-shadow: 0 8px 32px var(--shadow-color);
    padding: 1rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .calendar-card { padding: 1.5rem; }
  }

  .cal-embed {
    min-height: 500px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .cal-embed { min-height: 600px; }
  }

  .cta-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-dim);
  }

  .info-icon { color: var(--accent); }
</style>
