---
// FAQSection - Common Questions with Accordion
// Gym/fitness studio niche FAQs

const faqs = [
  {
    question: "How is this different from hiring a general marketing agency?",
    answer: "General agencies treat gyms like any other local business. We exclusively serve gym and fitness studio owners. Every system and strategy is built specifically for the fitness industry. We understand your margins, your sales cycle, and your member psychology."
  },
  {
    question: 'What do you mean by "zero ad spend"?',
    answer: "We start by generating immediate cashflow from assets you already have but aren't using. That revenue funds everything else. So from day one, the system pays for itself. You never have to dip into your own pocket for ad spend."
  },
  {
    question: "How much time will this require from me?",
    answer: "Minimal. Beyond your initial onboarding call and showing up to the appointments we book, we handle everything."
  },
  {
    question: "What if my studio is in a small market?",
    answer: "Small markets are often our best performers. Less competition means faster dominance. Our system works in markets as small as 50,000 population. During your strategy call, we'll assess your specific market opportunity."
  },
  {
    question: "How does the guarantee actually work?",
    answer: "We calculate the cost per appointment based on your package. If we promise 30 and deliver 22, we refund you for the 8 we missed. No hoops to jump through. No fine print."
  },
];
---

<section id="faq" class="faq-section noise-bg">
  <div class="container">
    <div class="section-header">
      <h2>Common Questions</h2>
      <p class="section-desc">
        Everything you need to know before booking your strategy call.
      </p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item" data-accordion>
          <button class="faq-trigger" aria-expanded="false" aria-controls={`faq-panel-${i}`}>
            <div class="faq-trigger-inner">
              <div class="q-badge">
                <span>Q</span>
              </div>
              <h3>{faq.question}</h3>
            </div>
            <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="faq-panel" id={`faq-panel-${i}`} role="region">
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-accordion] .faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('[data-accordion]')!;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('[data-accordion].open').forEach(openItem => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
      });

      // Toggle current
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />

<style>
  .faq-section {
    padding: 6rem 0;
    background: var(--page-bg);
  }

  @media (min-width: 1024px) {
    .faq-section { padding: 8rem 0; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 2rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .section-desc {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: var(--faq-hover-border);
  }

  /* Trigger button */
  .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 1rem;
  }

  .faq-trigger-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .q-badge {
    width: 2rem; height: 2rem;
    background: var(--accent-bg-strong);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .q-badge span {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    color: var(--accent);
  }

  .faq-trigger h3 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  /* Chevron */
  .chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item.open .chevron {
    transform: rotate(180deg);
  }

  /* Panel */
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  .faq-item.open .faq-panel {
    grid-template-rows: 1fr;
  }

  .faq-answer {
    overflow: hidden;
  }

  .faq-answer p {
    padding: 0 1.5rem 1.25rem 4.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
