---
// FAQSection - Common Questions with Accordion
// Gym/fitness studio niche FAQs

const faqs = [
  {
    question: "How is this different from hiring a general marketing agency?",
    answer: "Agencies generate leads, but leads don't pay the bills, members do. We solve the part most agencies ignore: the follow-up. Our AI contacts, nurtures, and books your leads 24/7 via text and voice. We're built exclusively for gym and fitness studio owners who are already running ads but losing leads to slow follow-up."
  },
  {
    question: "Will the AI sound robotic or put off my leads?",
    answer: "Not at all. Our AI is trained specifically for the fitness industry. It holds natural conversations, answers questions about your gym, handles objections, and books appointments, all in a way that feels personal and human. And if a lead ever shows signs of frustration or asks to speak with a real person, the system hands off to your team immediately. You stay in control."
  },
  {
    question: "Is this going to replace my staff?",
    answer: "No, and that's not the goal. The AI handles the repetitive follow-up work that your team doesn't have time for: the calls that go to voicemail, the fifth text to a cold lead, the 10pm inquiry. It frees your staff to focus on higher-leverage tasks like closing in-person, running great classes, and building relationships with existing members."
  },
  {
    question: "How much time will this require from me?",
    answer: "Minimal. Beyond your initial onboarding call and showing up to the appointments we book, we handle everything. The AI takes care of the follow-up so your staff can focus on what they do best."
  },
  {
    question: "What about calling and texting regulations?",
    answer: "We take compliance seriously. Our system follows all applicable regulations including proper disclosure, consent requirements, and calling/texting rules. Every interaction is transparent about AI involvement, and we ensure your business stays fully compliant."
  },
  {
    question: "How does the pay-per-appointment trial work?",
    answer: "We run a pay-per-appointment trial campaign. You only pay for qualified, booked appointments. We target 20, and if we fall short, you get a pro-rated refund for every one we missed. After the campaign, clients who see results continue on a simple monthly retainer."
  },
];
---

<section id="faq" class="faq-section noise-bg">
  <div class="container">
    <div class="section-header">
      <h2>Common Questions</h2>
      <p class="section-desc">
        Everything you need to know before booking your strategy call.
      </p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item" data-accordion>
          <button class="faq-trigger" aria-expanded="false" aria-controls={`faq-panel-${i}`}>
            <div class="faq-trigger-inner">
              <div class="q-badge">
                <span>Q</span>
              </div>
              <h3>{faq.question}</h3>
            </div>
            <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="faq-panel" id={`faq-panel-${i}`} role="region">
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-accordion] .faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('[data-accordion]')!;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('[data-accordion].open').forEach(openItem => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
      });

      // Toggle current
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />

<style>
  .faq-section {
    padding: 6rem 0;
    background: var(--page-bg);
  }

  @media (min-width: 1024px) {
    .faq-section { padding: 8rem 0; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 2rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .section-desc {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: var(--faq-hover-border);
  }

  /* Trigger button */
  .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 1rem;
  }

  .faq-trigger-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .q-badge {
    width: 2rem; height: 2rem;
    background: var(--accent-bg-strong);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .q-badge span {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    color: var(--accent);
  }

  .faq-trigger h3 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  /* Chevron */
  .chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item.open .chevron {
    transform: rotate(180deg);
  }

  /* Panel */
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  .faq-item.open .faq-panel {
    grid-template-rows: 1fr;
  }

  .faq-answer {
    overflow: hidden;
    min-height: 0;
  }

  .faq-answer p {
    padding: 0 1.5rem 1.25rem 4.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .faq-item.open .faq-answer p {
    opacity: 1;
  }
</style>
