---
// FAQSection - Common Questions with Accordion
// Gym/fitness studio niche FAQs

const faqs = [
  {
    question: "How is this different from hiring a regular marketing agency?",
    answer: "Most agencies give you leads and wish you luck closing them. We're different because we run the whole thing end to end. We wake up your old leads, bring in friends of your current members, run your ads, and handle every follow-up so people actually show up on your calendar. Built just for gym and studio owners who want real people walking through the door, not more form fills."
  },
  {
    question: "Do I need to already be running ads?",
    answer: "Nope. Most gyms we work with start without ads. We pull new consults straight from your old leads and your members' referrals first, which brings in cash from day one. Once that's producing, we layer ads on top. If you're already running ads, we take them over and plug them into the same system."
  },
  {
    question: "Will the AI sound robotic and turn my leads off?",
    answer: "Not at all. It's built specifically for gyms and studios. It has real conversations, answers questions about your gym, handles the usual objections, and books consults in a way that feels personal. If someone wants to talk to a real person, it hands them off to your team right away. You stay in full control."
  },
  {
    question: "Is this going to replace my staff?",
    answer: "No. Your staff is busy running classes and taking care of the members you already have. The AI does the stuff they don't have time for: the fifth text to a cold lead, the 10pm inquiry, the voicemail that never gets returned. Your team gets to focus on closing the people who walk through the door and running a great gym."
  },
  {
    question: "How much time will this take from me?",
    answer: "Barely any. There's a quick onboarding call at the start and then we handle everything. You just show up, greet the people we send your way, and sign them up."
  },
  {
    question: "What about rules around calling and texting people?",
    answer: "We take this seriously. Our setup follows all the rules around consent, disclosure, and how we reach out to people. Every message is compliant and your gym stays on the right side of every regulation."
  },
  {
    question: "How does the pay-per-consult trial work?",
    answer: "You only pay for the consults that actually show up on your calendar. We target 30 qualified consults in 30 days, and if we come up short, you get a refund for every one we missed. After the trial, the gyms who are happy with what we're doing keep going with us on a simple monthly basis."
  },
];
---

<section id="faq" class="faq-section noise-bg">
  <div class="container">
    <div class="section-header">
      <h2>Common Questions</h2>
      <p class="section-desc">
        Everything you need to know before booking your strategy call.
      </p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item" data-accordion>
          <button class="faq-trigger" aria-expanded="false" aria-controls={`faq-panel-${i}`}>
            <div class="faq-trigger-inner">
              <div class="q-badge">
                <span>Q</span>
              </div>
              <h3>{faq.question}</h3>
            </div>
            <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="faq-panel" id={`faq-panel-${i}`} role="region">
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-accordion] .faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('[data-accordion]')!;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('[data-accordion].open').forEach(openItem => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
      });

      // Toggle current
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />

<style>
  .faq-section {
    padding: 6rem 0;
    background: var(--page-bg);
  }

  @media (min-width: 1024px) {
    .faq-section { padding: 8rem 0; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 2rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .section-desc {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: var(--faq-hover-border);
  }

  /* Trigger button */
  .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 1rem;
  }

  .faq-trigger-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .q-badge {
    width: 2rem; height: 2rem;
    background: var(--accent-bg-strong);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .q-badge span {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-weight: 700;
    color: var(--accent);
  }

  .faq-trigger h3 {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  /* Chevron */
  .chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item.open .chevron {
    transform: rotate(180deg);
  }

  /* Panel */
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  .faq-item.open .faq-panel {
    grid-template-rows: 1fr;
  }

  .faq-answer {
    overflow: hidden;
    min-height: 0;
  }

  .faq-answer p {
    padding: 0 1.5rem 1.25rem 4.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .faq-item.open .faq-answer p {
    opacity: 1;
  }
</style>
