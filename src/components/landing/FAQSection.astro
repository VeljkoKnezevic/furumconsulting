---
// FAQSection - Frequently asked questions with native accordion
// Uses native <details>/<summary> for zero-JS accordion functionality

// FAQ data for schema
const faqs = [
	{
		question: "How soon can we see results?",
		answer: "Typically, we launch campaigns within 10 days of the audit. Our clients usually see their first new high-ticket enrollment within 48 hours of ads going live."
	},
	{
		question: "Is this just running Facebook Ads?",
		answer: "Absolutely not. While we use Meta as one of our engines, our service covers conversion optimization, sales training for your staff, and automated retention systems. Ads are only 20% of the equation."
	},
	{
		question: "Do you work with startups?",
		answer: "We specialize in scaling gyms that already have a proof of concept. If you're doing at least $10k/mo, we can help you explode. If you're a pre-launch startup, we have specific consulting packages for that."
	}
];
---

<!-- FAQ Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
})} />

<section class="faq-section" id="faq">
  <div class="container">
    <div class="content-wrapper">
      <!-- Section header -->
      <div class="section-header">
        <h2>Common Questions</h2>
        <p>Transparency is our first principle.</p>
      </div>

      <!-- FAQ Accordion -->
      <div class="faq-list">
        <details class="faq-item">
          <summary>
            <span>How soon can we see results?</span>
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <div class="faq-answer">
            <p>Typically, we launch campaigns within 10 days of the audit. Our clients usually see their first new high-ticket enrollment within 48 hours of ads going live.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Is this just running Facebook Ads?</span>
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <div class="faq-answer">
            <p>Absolutely not. While we use Meta as one of our engines, our service covers conversion optimization, sales training for your staff, and automated retention systems. Ads are only 20% of the equation.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Do you work with startups?</span>
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <div class="faq-answer">
            <p>We specialize in scaling gyms that already have a proof of concept. If you're doing at least $10k/mo, we can help you explode. If you're a pre-launch startup, we have specific consulting packages for that.</p>
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<script>
  // Optional: Close other items when one opens (single-select behavior)
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        document.querySelectorAll('.faq-item').forEach(other => {
          if (other !== item && other.open) {
            other.open = false;
          }
        });
      }
    });
  });
</script>

<style>
  .faq-section {
    padding: 6rem 0;
    background: white;
  }

  @media (min-width: 768px) {
    .faq-section {
      padding: 8rem 0;
    }
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .content-wrapper {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .section-header p {
    color: hsl(var(--forest) / 0.6);
  }

  /* FAQ list */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* FAQ item */
  .faq-item {
    border: 1px solid hsl(var(--forest) / 0.1);
    border-radius: 0.75rem;
    padding: 2rem;
    transition: box-shadow 0.3s;
  }

  .faq-item[open] {
    box-shadow: 0 4px 20px hsl(var(--foreground) / 0.08);
  }

  /* Summary (question) */
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: hsl(var(--foreground));
    list-style: none;
    transition: color 0.2s;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary .icon {
    flex-shrink: 0;
    color: hsl(var(--muted-foreground));
    transition: transform 0.2s, color 0.2s;
  }

  .faq-item[open] summary .icon {
    transform: rotate(45deg);
    color: hsl(var(--forest));
  }

  .faq-item summary:hover {
    color: hsl(var(--forest));
  }

  .faq-item summary:hover .icon {
    color: hsl(var(--forest));
  }

  /* Answer */
  .faq-answer {
    padding-top: 1rem;
  }

  .faq-answer p {
    color: hsl(var(--forest) / 0.7);
    line-height: 1.7;
  }
</style>
