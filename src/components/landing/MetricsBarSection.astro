---
// MetricsBarSection - Key metrics strip between hero and content
---

<section class="metrics-section">
  <div class="container">
    <div class="metrics-grid">
      <div class="metric">
        <p class="metric-value metric-green">30+</p>
        <p class="metric-label">Qualified Appointments</p>
      </div>
      <div class="metric">
        <p class="metric-value">&lt;60s</p>
        <p class="metric-label">Lead Response Time</p>
      </div>
      <div class="metric">
        <p class="metric-value">24/7</p>
        <p class="metric-label">AI Follow-Up Active</p>
      </div>
      <div class="metric">
        <p class="metric-value">0</p>
        <p class="metric-label">Leads Missed</p>
      </div>
    </div>
  </div>
</section>

<style>
  .metrics-section {
    padding: 4rem 0;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    background: var(--surface);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 2rem; }
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .metrics-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .metric { text-align: center; }

  .metric-value {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
  }

  .metric-green { color: var(--accent); }

  .metric-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
</style>
