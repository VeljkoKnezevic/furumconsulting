---
// HeroSection - Main hero with headline, CTAs, and dashboard visual
// Themed via CSS variables
---

<section class="hero-section noise-bg">
  <div class="grid-bg"></div>
  <div class="glow-orb glow-orb-1"></div>
  <div class="glow-orb glow-orb-2"></div>

  <div class="container">
    <div class="hero-grid">
      <!-- Left Content -->
      <div class="hero-content">
        <div class="trust-badge">
          <span class="pulse-dot"></span>
          <span>For Gym & Studio Owners Ready to Grow</span>
        </div>

        <h1 class="hero-headline">
          30 Qualified Consults<br/>
          Booked in Your<br/>
          <span class="highlight">First 30 Days.</span>
        </h1>

        <p class="hero-subheadline">
          A consistent flow of new people coming through your doors every single day. We reactivate your old leads, bring in referrals from your members, run your ads, and handle every follow-up so your team can focus on closing. Try it risk-free, pay per consult.
        </p>

        <div class="cta-buttons">
          <a href="#book-call" class="btn btn-hero">
            Book Your Strategy Call
            <iconify-icon icon="lucide:arrow-right" class="btn-icon"></iconify-icon>
          </a>
        </div>

      </div>

      <!-- Right Visual - Dashboard Card -->
      <div class="hero-visual">
        <div class="dashboard-card">
          <div class="dashboard-header">
            <div>
              <p class="dashboard-label">New Consults Booked</p>
              <p class="dashboard-value">+32</p>
            </div>
            <div class="dashboard-badge">This Month</div>
          </div>

          <div class="lead-list">
            <div class="lead-item">
              <div class="lead-icon-wrap">
                <iconify-icon icon="lucide:user" class="lead-icon"></iconify-icon>
              </div>
              <div class="lead-info">
                <p class="lead-name">Sarah M.</p>
                <p class="lead-detail">Pilates Intro Class &bull; Booked</p>
              </div>
              <span class="lead-time">2m ago</span>
            </div>

            <div class="lead-item">
              <div class="lead-icon-wrap">
                <iconify-icon icon="lucide:user" class="lead-icon"></iconify-icon>
              </div>
              <div class="lead-info">
                <p class="lead-name">Marcus T.</p>
                <p class="lead-detail">CrossFit Foundations &bull; Booked</p>
              </div>
              <span class="lead-time">12m ago</span>
            </div>

            <div class="lead-item">
              <div class="lead-icon-wrap">
                <iconify-icon icon="lucide:user" class="lead-icon"></iconify-icon>
              </div>
              <div class="lead-info">
                <p class="lead-name">Jennifer K.</p>
                <p class="lead-detail">Kickboxing Trial &bull; Booked</p>
              </div>
              <span class="lead-time">34m ago</span>
            </div>
          </div>

          <div class="dashboard-footer">
            <iconify-icon icon="lucide:activity" class="footer-icon"></iconify-icon>
            <span>New consults coming through daily</span>
          </div>
        </div>

        <!-- Floating Element -->
        <div class="floating-card">
          <div class="floating-icon-wrap">
            <iconify-icon icon="lucide:trending-up" class="floating-icon"></iconify-icon>
          </div>
          <div>
            <p class="floating-label">Lead Response</p>
            <p class="floating-value">&lt;60s</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    overflow: hidden;
    background: var(--page-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .glow-orb-1 {
    top: 25%; right: 0;
    width: 24rem; height: 24rem;
    background: var(--accent-bg);
  }

  .glow-orb-2 {
    bottom: 0; left: 0;
    width: 18rem; height: 18rem;
    background: var(--accent-bg);
    opacity: 0.5;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 1.5rem 5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 5rem 2rem 8rem; }
  }

  .hero-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--card-hover-bg);
    border: 1px solid var(--border);
    border-radius: 9999px;
    width: fit-content;
  }

  .pulse-dot {
    width: 0.5rem; height: 0.5rem;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .trust-badge span:last-child {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .hero-headline {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(3.25rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .highlight { color: var(--accent); }

  .hero-subheadline {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 36rem;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
  }

  @media (min-width: 640px) {
    .cta-buttons { flex-direction: row; }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    border-radius: 0.75rem;
    transition: all 0.3s;
  }

  .btn-hero {
    background: var(--accent);
    color: white;
    box-shadow: 0 0 40px var(--glow);
  }

  .btn-hero:hover {
    background: var(--accent-dark);
    transform: scale(1.05);
  }

  .btn-icon { font-size: 1.25rem; }

  .btn-outline {
    background: var(--outline-bg);
    border: 1px solid var(--outline-border);
    color: var(--outline-text);
  }

  .btn-outline:hover {
    background: var(--outline-bg-hover);
  }

  .hero-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 1rem;
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-dim);
  }

  .check-icon { color: var(--accent); }

  /* Right Visual */
  .hero-visual {
    display: none;
    position: relative;
  }

  @media (min-width: 1024px) {
    .hero-visual { display: block; }
  }

  .dashboard-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 0 40px var(--glow);
  }

  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .dashboard-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .dashboard-value {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--accent);
  }

  .dashboard-badge {
    padding: 0.25rem 0.75rem;
    background: var(--green-badge-bg);
    color: var(--green-badge-text);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .lead-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .lead-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--card-hover-bg);
    border-radius: 0.75rem;
  }

  .lead-icon-wrap {
    width: 2.5rem; height: 2.5rem;
    background: var(--accent-bg-strong);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lead-icon { color: var(--accent); }
  .lead-info { flex: 1; }
  .lead-name { font-weight: 500; color: var(--text-primary); }
  .lead-detail { font-size: 0.875rem; color: var(--text-muted); }
  .lead-time { font-size: 0.875rem; color: var(--green-badge-text); }

  .dashboard-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-icon { color: var(--accent); }

  .floating-card {
    position: absolute;
    top: -1rem; right: -1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    animation: float 6s ease-in-out infinite;
  }

  .floating-icon-wrap {
    width: 2rem; height: 2rem;
    background: var(--green-badge-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .floating-icon { color: var(--green-badge-text); font-size: 0.875rem; }
  .floating-label { font-size: 0.75rem; color: var(--text-muted); }
  .floating-value { font-weight: 600; color: var(--text-primary); }
</style>
