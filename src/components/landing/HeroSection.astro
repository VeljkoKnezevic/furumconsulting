---
// HeroSection - Main hero with headline, image, testimonial card, and CTA
---

<section class="hero-section">
  <div class="container">
    <div class="hero-grid">
      <!-- Left Content -->
      <div class="hero-content">
        <!-- Badge -->
        <div class="hero-badge">
          <span>Exclusively for Gym Owners</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-headline">
          Empty Floors <br/>Cost More Than <br/><span class="highlight">Marketing.</span>
        </h1>

        <!-- Description -->
        <p class="hero-description">
          We help high-ticket fitness facilities reach $100k+ MRR through performance-based acquisition systems and bulletproof retention strategies. No fluff. Just growth.
        </p>

        <!-- CTA Row -->
        <div class="cta-row">
          <a href="#booking" class="btn btn-primary">
            Book Your Free Growth Audit
          </a>
          <div class="social-proof-mini">
            <div class="avatars">
              <div class="avatar"></div>
              <div class="avatar"></div>
              <div class="avatar"></div>
            </div>
            <div class="social-proof-text">
              <span class="social-proof-strong">Join 150+ Gym Owners</span>
              <span class="social-proof-sub">Scaling aggressively this month</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Image -->
      <div class="hero-image-wrapper">
        <div class="hero-image">
          <img
            src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?q=80&w=1470&auto=format&fit=crop"
            alt="Premium gym interior with modern equipment"
            loading="eager"
          />
        </div>

        <!-- Testimonial Card -->
        <div class="testimonial-card">
          <div class="stars">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="testimonial-text">"Furum added 42 high-ticket members in our first 30 days. Our ROI was over 5.5x."</p>
          <p class="testimonial-author">— Marcus Reed, Elite Athletics</p>
        </div>

        <!-- Decorative blob -->
        <div class="decorative-blob"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 8rem;
    padding-bottom: 5rem;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-section {
      padding-top: 13rem;
      padding-bottom: 10rem;
    }
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 7fr 5fr;
      gap: 3rem;
    }
  }

  /* Hero Content */
  .hero-content {
    animation: fade-in 0.8s ease forwards;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Badge */
  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: hsl(var(--forest) / 0.05);
    border: 1px solid hsl(var(--forest) / 0.2);
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .hero-badge span {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 0.9;
    color: hsl(var(--forest));
    margin-bottom: 2rem;
  }

  .hero-headline .highlight {
    color: hsl(var(--gold));
  }

  /* Description */
  .hero-description {
    font-size: 1.25rem;
    color: hsl(var(--foreground) / 0.8);
    max-width: 36rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  /* CTA Row */
  .cta-row {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .cta-row {
      flex-direction: row;
      align-items: center;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 2.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.2s;
    text-align: center;
  }

  .btn-primary {
    background: hsl(var(--forest));
    color: white;
    box-shadow: 0 10px 40px hsl(var(--forest) / 0.1);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 50px hsl(var(--forest) / 0.15);
  }

  /* Social Proof Mini */
  .social-proof-mini {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.5rem;
  }

  .avatars {
    display: flex;
    margin-left: -0.75rem;
  }

  .avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 2px solid hsl(var(--cream));
    margin-left: -0.75rem;
  }

  .avatar:nth-child(1) {
    background: hsl(var(--muted));
  }

  .avatar:nth-child(2) {
    background: hsl(var(--border));
  }

  .avatar:nth-child(3) {
    background: hsl(var(--muted-foreground) / 0.3);
  }

  .social-proof-text {
    display: flex;
    flex-direction: column;
  }

  .social-proof-strong {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .social-proof-sub {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  /* Hero Image Wrapper */
  .hero-image-wrapper {
    position: relative;
    animation: fade-in 0.8s ease 0.3s forwards;
    opacity: 0;
  }

  .hero-image {
    position: relative;
    z-index: 10;
  }

  .hero-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    clip-path: polygon(0 0, 100% 5%, 100% 100%, 0 95%);
    box-shadow: 0 25px 50px -12px hsl(var(--forest) / 0.25);
  }

  @media (min-width: 1024px) {
    .hero-image img {
      height: 600px;
    }
  }

  /* Testimonial Card */
  .testimonial-card {
    position: absolute;
    bottom: -2.5rem;
    left: -2.5rem;
    background: white;
    padding: 2rem;
    box-shadow: 0 25px 50px -12px hsl(var(--forest) / 0.15);
    border: 1px solid hsl(var(--forest) / 0.05);
    max-width: 280px;
    z-index: 20;
  }

  @media (max-width: 1023px) {
    .testimonial-card {
      position: relative;
      bottom: auto;
      left: auto;
      max-width: 100%;
      margin-top: 1.5rem;
    }
  }

  .stars {
    display: flex;
    gap: 0.125rem;
    color: hsl(var(--gold));
    margin-bottom: 0.5rem;
  }

  .testimonial-text {
    font-size: 0.875rem;
    font-style: italic;
    color: hsl(var(--foreground) / 0.8);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .testimonial-author {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Decorative blob */
  .decorative-blob {
    position: absolute;
    top: -2.5rem;
    right: -2.5rem;
    width: 16rem;
    height: 16rem;
    background: hsl(var(--forest) / 0.05);
    border-radius: 50%;
    filter: blur(48px);
    z-index: 0;
  }
</style>
