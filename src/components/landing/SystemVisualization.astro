---
// SystemVisualization - Interactive flow diagram showing the AI appointment system
---

<section class="system-section noise-bg">
  <div class="grid-bg"></div>
  <div class="glow-orb glow-orb-1"></div>
  <div class="glow-orb glow-orb-2"></div>

  <div class="container">
    <!-- Header -->
    <div class="system-header">
      <div class="status-badge">
        <span class="pulse-dot"></span>
        <span>System Active 24/7</span>
      </div>
      <h1 class="system-headline">How Your Leads Become Members</h1>
      <p class="system-subheadline">
        Every lead contacted. Every conversation handled. Every appointment booked. You just close the sale.
      </p>
    </div>

    <!-- Flow Diagram -->
    <div class="flow">

      <!-- Entry Points -->
      <div class="flow-row">
        <div class="flow-card flow-card--blue">
          <div class="flow-card__icon">
            <iconify-icon icon="lucide:megaphone" width="28"></iconify-icon>
          </div>
          <div class="flow-card__title">Your Ad Leads</div>
          <div class="flow-card__desc">Someone fills out your ad form and enters the system instantly</div>
        </div>

        <div class="flow-card flow-card--blue">
          <div class="flow-card__icon">
            <iconify-icon icon="lucide:database" width="28"></iconify-icon>
          </div>
          <div class="flow-card__title">Database Reactivation</div>
          <div class="flow-card__desc">Your old leads get texted and responders enter the system</div>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flow-arrow">
        <div class="flow-arrow__line flow-arrow__line--blue-to-amber"></div>
      </div>

      <!-- Golden Followup -->
      <div class="flow-card flow-card--amber flow-card--wide">
        <div class="flow-card__badge">The Engine</div>
        <div class="flow-card__title flow-card__title--lg">Golden Followup System</div>
        <div class="flow-card__desc">Your leads get 14 touchpoints over 30 days. Calls and texts on an intelligent cadence that never stops until they book, opt out, or are exhausted.</div>

        <div class="cadence">
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber)">D1</span>
            <div class="cadence-dots"><span></span><span></span><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber)">D2</span>
            <div class="cadence-dots"><span></span><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber)">D3</span>
            <div class="cadence-dots"><span></span><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-mid)">D4</span>
            <div class="cadence-dots"><span></span><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-mid)">D5</span>
            <div class="cadence-dots"><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-dark)">D8</span>
            <div class="cadence-dots"><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-darker)">D14</span>
            <div class="cadence-dots"><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-darkest)">D30</span>
            <div class="cadence-dots"><span></span></div>
          </div>
          <div class="cadence-step">
            <span class="cadence-day" style="--step-color: var(--amber-darkest)">30+</span>
            <div class="cadence-dots"><span></span></div>
          </div>
        </div>
      </div>

      <!-- Split Arrow -->
      <div class="flow-arrow flow-arrow--split">
        <div class="flow-arrow__branch flow-arrow__branch--left"></div>
        <div class="flow-arrow__center"></div>
        <div class="flow-arrow__branch flow-arrow__branch--right"></div>
      </div>

      <!-- Voice + Text -->
      <div class="flow-row">
        <div class="flow-card flow-card--purple">
          <div class="flow-card__icon">
            <iconify-icon icon="lucide:phone-call" width="28"></iconify-icon>
          </div>
          <div class="flow-card__title">AI Voice Agent</div>
          <div class="flow-card__desc">Calls your leads, qualifies them, answers their questions, and books appointments.</div>
          <div class="flow-card__note flow-card__note--purple">Always runs on cadence</div>
        </div>

        <div class="flow-card flow-card--green">
          <div class="flow-card__icon">
            <iconify-icon icon="lucide:message-square" width="28"></iconify-icon>
          </div>
          <div class="flow-card__title">AI Text Agent</div>
          <div class="flow-card__desc">When a lead replies, the AI takes over. Qualifies, handles objections, and books via text. 24/7.</div>
          <div class="flow-card__note flow-card__note--green">Activates on reply. Scheduled texts pause, AI takes over.</div>
        </div>
      </div>

      <!-- Converge Arrow -->
      <div class="flow-arrow">
        <div class="flow-arrow__line flow-arrow__line--to-pink"></div>
      </div>

      <!-- Appointment Booked -->
      <div class="flow-card flow-card--pink flow-card--wide flow-card--center">
        <div class="flow-card__title flow-card__title--lg">
          <iconify-icon icon="lucide:calendar-check" width="28"></iconify-icon>
          Appointment Booked
        </div>
        <div class="flow-card__desc">All follow-up stops instantly. Your lead is confirmed, you get notified, and reminders begin.</div>
      </div>

      <!-- Arrow -->
      <div class="flow-arrow">
        <div class="flow-arrow__line flow-arrow__line--pink-to-orange"></div>
      </div>

      <!-- Reminders -->
      <div class="flow-card flow-card--orange flow-card--wide">
        <div class="reminders-grid">
          <div class="reminder-item">
            <iconify-icon icon="lucide:mail" width="26" class="reminder-icon"></iconify-icon>
            <div class="reminder-time">24h before</div>
            <div class="reminder-type">Text Reminder</div>
          </div>
          <div class="reminder-item">
            <iconify-icon icon="lucide:phone" width="26" class="reminder-icon"></iconify-icon>
            <div class="reminder-time">4h before</div>
            <div class="reminder-type">Voice Confirmation</div>
          </div>
          <div class="reminder-item">
            <iconify-icon icon="lucide:map-pin" width="26" class="reminder-icon"></iconify-icon>
            <div class="reminder-time">1h before</div>
            <div class="reminder-type">Final Text</div>
          </div>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flow-arrow">
        <div class="flow-arrow__line flow-arrow__line--orange-to-neutral"></div>
      </div>

      <!-- Outcomes -->
      <div class="flow-row flow-row--three">
        <div class="flow-card flow-card--success flow-card--center">
          <iconify-icon icon="lucide:trophy" width="32" class="outcome-icon outcome-icon--success"></iconify-icon>
          <div class="flow-card__title">Showed Up</div>
          <div class="flow-card__desc">You close the deal</div>
        </div>

        <div class="flow-card flow-card--red flow-card--center">
          <iconify-icon icon="lucide:refresh-cw" width="32" class="outcome-icon outcome-icon--red"></iconify-icon>
          <div class="flow-card__title">No Show</div>
          <div class="flow-card__desc">Recovery sequence activates and re-enters followup</div>
        </div>

        <div class="flow-card flow-card--red flow-card--center">
          <iconify-icon icon="lucide:calendar-x" width="32" class="outcome-icon outcome-icon--red"></iconify-icon>
          <div class="flow-card__title">Cancelled</div>
          <div class="flow-card__desc">Instant rebooking attempt with new times offered</div>
        </div>
      </div>
    </div>

    <!-- Safety Bar -->
    <div class="safety-bar">
      <div class="safety-item">
        <iconify-icon icon="lucide:shield-off" width="24" class="safety-icon"></iconify-icon>
        <div class="safety-label">Instant Opt-Out</div>
        <div class="safety-desc">STOP = full stop</div>
      </div>
      <div class="safety-item">
        <iconify-icon icon="lucide:user-check" width="24" class="safety-icon"></iconify-icon>
        <div class="safety-label">Human Handoff</div>
        <div class="safety-desc">Transfer to your staff</div>
      </div>
      <div class="safety-item">
        <iconify-icon icon="lucide:user-plus" width="24" class="safety-icon"></iconify-icon>
        <div class="safety-label">Lead Returns</div>
        <div class="safety-desc">Auto re-engagement</div>
      </div>
      <div class="safety-item">
        <iconify-icon icon="lucide:eye" width="24" class="safety-icon"></iconify-icon>
        <div class="safety-label">Ghost Detection</div>
        <div class="safety-desc">Nudge stalled chats</div>
      </div>
      <div class="safety-item">
        <iconify-icon icon="lucide:shield-check" width="24" class="safety-icon"></iconify-icon>
        <div class="safety-label">TCPA Compliant</div>
        <div class="safety-desc">Full compliance</div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="stat-card">
        <div class="stat-num">&lt;60s</div>
        <div class="stat-label">First Contact</div>
        <div class="stat-sub">Speed to lead</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">14</div>
        <div class="stat-label">Touchpoints</div>
        <div class="stat-sub">Over 30 days</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">24/7</div>
        <div class="stat-label">Always On</div>
        <div class="stat-sub">Never misses</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">0</div>
        <div class="stat-label">Leads Missed</div>
        <div class="stat-sub">Every one followed up</div>
      </div>
    </div>

    <!-- Client View Note -->
    <div class="client-note">
      <div class="client-note__title">
        <iconify-icon icon="lucide:monitor" width="18"></iconify-icon>
        What you see
      </div>
      <div class="client-note__desc">
        A simple dashboard showing your leads moving through stages: New, Contacted, In Conversation, Booked, Showed Up.
        You get a text and email every time an appointment is booked with the lead's name, phone number, and time.
        You show up, greet the person, close the sale. Everything else is automated.
      </div>
    </div>

    <!-- CTA -->
    <div class="system-cta">
      <a href="/#book-call" class="btn btn-primary">
        Book Your Strategy Call
        <iconify-icon icon="lucide:arrow-right" width="20"></iconify-icon>
      </a>
    </div>
  </div>
</section>

<script>
  // Hover-only: no click behavior, text is highlightable
</script>

<style>
  /* ── Section Colors ── */
  .system-section {
    --blue: #3B82F6;
    --amber: #F59E0B;
    --amber-mid: #D97706;
    --amber-dark: #B45309;
    --amber-darker: #92400E;
    --amber-darkest: #78350F;
    --purple: #8B5CF6;
    --green: #10B981;
    --pink: #EC4899;
    --orange: #F97316;
    --red: #EF4444;
  }

  .system-section {
    position: relative;
    background: var(--page-bg);
    overflow: hidden;
    padding-bottom: 5rem;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .glow-orb-1 {
    top: 10%; right: -5%;
    width: 24rem; height: 24rem;
    background: var(--accent-bg);
  }

  .glow-orb-2 {
    bottom: 10%; left: -5%;
    width: 18rem; height: 18rem;
    background: var(--accent-bg);
    opacity: 0.5;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .container { padding: 0 3rem; }
  }

  /* ── Header ── */
  .system-header {
    padding: 7rem 0 3rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .pulse-dot {
    width: 0.5rem; height: 0.5rem;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .status-badge span:last-child {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .system-headline {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: clamp(2.75rem, 5.5vw, 4rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .system-subheadline {
    font-size: 1.3rem;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 44rem;
    line-height: 1.6;
  }

  /* ── Flow Layout ── */
  .flow {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .flow-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
  }

  .flow-row--three {
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 640px) {
    .flow-row { grid-template-columns: 1fr; }
    .flow-row--three { grid-template-columns: 1fr; }
  }

  /* ── Flow Card Base ── */
  .flow-card {
    padding: 2rem;
    border-radius: 1rem;
    transition: all 0.3s ease;
    border: 1px solid transparent;
    user-select: text;
  }

  .flow-card--wide {
    width: 100%;
  }

  .flow-card--center {
    text-align: center;
  }

  .flow-card__icon {
    width: 3.25rem; height: 3.25rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .flow-card__badge {
    display: inline-block;
    padding: 0.35rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
  }

  .flow-card__title {
    font-family: var(--font-display, 'Clash Grotesk', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.375rem;
  }

  .flow-card__title--lg {
    font-size: 1.6rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .flow-card--center .flow-card__title--lg {
    justify-content: center;
  }

  .flow-card__desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .flow-card__note {
    margin-top: 1rem;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ── Card Color Variants ── */

  /* Blue */
  .flow-card--blue {
    background: color-mix(in srgb, var(--blue) 6%, transparent);
    border-color: color-mix(in srgb, var(--blue) 15%, transparent);
  }
  .flow-card--blue:hover {
    background: color-mix(in srgb, var(--blue) 12%, transparent);
    border-color: color-mix(in srgb, var(--blue) 40%, transparent);
  }
  .flow-card--blue .flow-card__icon {
    background: color-mix(in srgb, var(--blue) 15%, transparent);
    color: var(--blue);
  }
  .flow-card--blue .flow-card__title { color: var(--blue); }

  /* Amber */
  .flow-card--amber {
    background: linear-gradient(135deg, color-mix(in srgb, var(--amber) 8%, transparent), color-mix(in srgb, var(--amber) 3%, transparent));
    border-color: color-mix(in srgb, var(--amber) 20%, transparent);
  }
  .flow-card--amber:hover {
    background: linear-gradient(135deg, color-mix(in srgb, var(--amber) 15%, transparent), color-mix(in srgb, var(--amber) 8%, transparent));
    border-color: color-mix(in srgb, var(--amber) 50%, transparent);
  }
  .flow-card--amber .flow-card__badge {
    background: color-mix(in srgb, var(--amber) 20%, transparent);
    color: var(--amber);
  }
  .flow-card--amber .flow-card__title { color: var(--amber); }

  /* Purple */
  .flow-card--purple {
    background: color-mix(in srgb, var(--purple) 6%, transparent);
    border-color: color-mix(in srgb, var(--purple) 15%, transparent);
  }
  .flow-card--purple:hover {
    background: color-mix(in srgb, var(--purple) 12%, transparent);
    border-color: color-mix(in srgb, var(--purple) 40%, transparent);
  }
  .flow-card--purple .flow-card__icon {
    background: color-mix(in srgb, var(--purple) 15%, transparent);
    color: var(--purple);
  }
  .flow-card--purple .flow-card__title { color: var(--purple); }
  .flow-card__note--purple {
    background: color-mix(in srgb, var(--purple) 10%, transparent);
    color: #A78BFA;
  }

  /* Green */
  .flow-card--green {
    background: color-mix(in srgb, var(--green) 6%, transparent);
    border-color: color-mix(in srgb, var(--green) 15%, transparent);
  }
  .flow-card--green:hover {
    background: color-mix(in srgb, var(--green) 12%, transparent);
    border-color: color-mix(in srgb, var(--green) 40%, transparent);
  }
  .flow-card--green .flow-card__icon {
    background: color-mix(in srgb, var(--green) 15%, transparent);
    color: var(--green);
  }
  .flow-card--green .flow-card__title { color: var(--green); }
  .flow-card__note--green {
    background: color-mix(in srgb, var(--green) 10%, transparent);
    color: #6EE7B7;
  }

  /* Pink */
  .flow-card--pink {
    background: linear-gradient(135deg, color-mix(in srgb, var(--pink) 8%, transparent), color-mix(in srgb, var(--pink) 3%, transparent));
    border-color: color-mix(in srgb, var(--pink) 20%, transparent);
  }
  .flow-card--pink:hover {
    background: linear-gradient(135deg, color-mix(in srgb, var(--pink) 15%, transparent), color-mix(in srgb, var(--pink) 8%, transparent));
    border-color: color-mix(in srgb, var(--pink) 50%, transparent);
  }
  .flow-card--pink .flow-card__title { color: var(--pink); }

  /* Orange */
  .flow-card--orange {
    background: color-mix(in srgb, var(--orange) 6%, transparent);
    border-color: color-mix(in srgb, var(--orange) 15%, transparent);
  }
  .flow-card--orange:hover {
    background: color-mix(in srgb, var(--orange) 12%, transparent);
    border-color: color-mix(in srgb, var(--orange) 40%, transparent);
  }

  /* Success (green outcome) */
  .flow-card--success {
    background: color-mix(in srgb, var(--green) 6%, transparent);
    border-color: color-mix(in srgb, var(--green) 15%, transparent);
  }
  .flow-card--success .flow-card__title { color: var(--green); }

  /* Red */
  .flow-card--red {
    background: color-mix(in srgb, var(--red) 6%, transparent);
    border-color: color-mix(in srgb, var(--red) 15%, transparent);
  }
  .flow-card--red:hover {
    background: color-mix(in srgb, var(--red) 12%, transparent);
    border-color: color-mix(in srgb, var(--red) 40%, transparent);
  }
  .flow-card--red .flow-card__title { color: var(--red); }

  /* ── Outcome Icons ── */
  .outcome-icon {
    display: block;
    margin: 0 auto 0.75rem;
  }
  .outcome-icon--success { color: var(--green); }
  .outcome-icon--red { color: var(--red); }

  /* ── Cadence Visual ── */
  .cadence {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }

  .cadence-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .cadence-day {
    padding: 0.35rem 0.625rem;
    border-radius: 0.375rem;
    font-size: 0.85rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--step-color) 15%, transparent);
    color: var(--step-color);
  }

  .cadence-dots {
    display: flex;
    gap: 0.2rem;
  }

  .cadence-dots span {
    width: 0.5rem; height: 0.5rem;
    border-radius: 50%;
    background: var(--step-color);
  }

  /* ── Flow Arrows ── */
  .flow-arrow {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0;
  }

  .flow-arrow__line {
    width: 2px;
    height: 2rem;
  }

  .flow-arrow__line--blue-to-amber {
    background: linear-gradient(to bottom, var(--blue), var(--amber));
  }

  .flow-arrow__line--to-pink {
    background: linear-gradient(to bottom, var(--text-dim), var(--pink));
  }

  .flow-arrow__line--pink-to-orange {
    background: linear-gradient(to bottom, var(--pink), var(--orange));
  }

  .flow-arrow__line--orange-to-neutral {
    background: linear-gradient(to bottom, var(--orange), var(--text-dim));
  }

  .flow-arrow--split {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .flow-arrow__branch {
    height: 2px;
    width: 12rem;
  }

  .flow-arrow__branch--left {
    background: linear-gradient(to right, transparent, var(--purple));
  }

  .flow-arrow__branch--right {
    background: linear-gradient(to left, transparent, var(--green));
  }

  .flow-arrow__center {
    width: 2px;
    height: 2rem;
    background: var(--border);
  }

  @media (max-width: 640px) {
    .flow-arrow__branch { width: 4rem; }
  }

  /* ── Reminders Grid ── */
  .reminders-grid {
    display: flex;
    justify-content: center;
    gap: 3.5rem;
    flex-wrap: wrap;
  }

  .reminder-item {
    text-align: center;
  }

  .reminder-icon {
    color: var(--orange);
    margin-bottom: 0.375rem;
  }

  .reminder-time {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--orange);
  }

